---
import CvLayout from '../layouts/CvLayout.astro';
import FormField from '../components/FormField.astro';
import Button from '../components/Button.astro';
import { getSiteData } from '../lib/data';

const site = await getSiteData();
---

<CvLayout
  seo={{
    title: 'Contact',
    description: 'Get in touch with Thomas Rouaud. Fill in the contact form.'
  }}
  breadcrumb="Contact"
>
  <div class="cv-subpage-header">
    <a href="/" class="cv-subpage-back">&#x1438; Retour à la page d'accueil</a>
    <h1 class="cv-subpage-title">Contact</h1>
  </div>

  <div class="cv-subpage-content">
    <div style="max-width: 600px;">
      <form data-webhook={site.webhookUrl} data-webhook-token={site.webhookToken || ''} novalidate>
        <!-- Honeypot anti-spam -->
        <div class="absolute opacity-0 -z-10 h-0 overflow-hidden" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
        </div>
        <FormField type="text" name="firstname" label="First name" required icon="user" maxlength={100} autocomplete="given-name" />
        <FormField type="text" name="lastname" label="Last name" required icon="user" maxlength={100} autocomplete="family-name" />
        <FormField type="email" name="email" label="Email" required icon="at" maxlength={254} autocomplete="email" />
        <FormField type="tel" name="phone" label="Phone" icon="phone" maxlength={20} autocomplete="tel" />
        <FormField type="textarea" name="message" label="Message" required icon="chat-text" maxlength={5000} />
        <div class="cf-turnstile mt-m" data-sitekey={site.turnstileSiteKey} data-appearance="interaction-only"></div>
        <Button type="submit" variant="primary" icon="paper-plane-tilt" class="mt-m">Send</Button>
        <div id="form-feedback" class="form-feedback" role="status" aria-live="polite"></div>
      </form>
    </div>
  </div>

  <script is:inline>
    window.onTurnstileLoad = function() {
      document.querySelectorAll('.cf-turnstile').forEach(function(el) {
        if (!el.querySelector('iframe')) {
          window.turnstile.render(el, { sitekey: el.dataset.sitekey });
        }
      });
    };
  </script>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onTurnstileLoad&render=explicit" async defer data-astro-rerun></script>
</CvLayout>
