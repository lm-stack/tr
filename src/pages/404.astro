---
import Bare from '../layouts/Bare.astro';
---

<Bare
  seo={{ title: 'Page introuvable', description: "La page que vous recherchez n'existe pas ou a été déplacée." }}
  noindex
>
  <div class="min-h-screen flex flex-col items-center justify-center px-m text-center" data-pagefind-ignore="all">
    <p class="text-[clamp(8rem,25vw,20rem)] font-bold leading-none text-primary">404</p>
    <h1 class="text-h2 mt-m mb-xs">Page introuvable</h1>
    <p class="text-text mb-l">La page que vous recherchez n'existe pas ou a été déplacée.</p>
    <a href="/" class="cv-btn-submit inline-block">Retour à l'accueil</a>
  </div>
</Bare>
