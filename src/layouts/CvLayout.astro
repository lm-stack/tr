---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import JsonLd from '../components/JsonLd.astro';
import { getSiteData } from '../lib/data';
import { Icon } from 'astro-icon/components';
import { toIconName } from '../lib/data';

interface Props {
  seo: {
    title: string;
    description: string;
    ogImage?: string;
  };
  breadcrumb?: string;
  isHome?: boolean;
  noindex?: boolean;
}

const site = await getSiteData();
const { seo, breadcrumb, isHome = false, noindex = false } = Astro.props;
const currentUrl = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={site.lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' data: https://challenges.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' data:; font-src 'self'; img-src 'self' data: https://www.googletagmanager.com https://www.google-analytics.com; connect-src 'self' https:; frame-src https://challenges.cloudflare.com https://www.googletagmanager.com;">
  <meta name="referrer" content="strict-origin-when-cross-origin">
  <title>{site.name} | {seo.title}</title>
  <meta name="description" content={seo.description}>
  {noindex && <meta name="robots" content="noindex, nofollow">}
  <link rel="canonical" href={`${site.url}${currentUrl}`}>

  <!-- Open Graph -->
  <meta property="og:title" content={`${seo.title} | ${site.name}`}>
  <meta property="og:description" content={seo.description}>
  <meta property="og:image" content={`${site.url}${seo.ogImage || site.ogImage}`}>
  <meta property="og:url" content={`${site.url}${currentUrl}`}>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content={site.name}>
  <meta property="og:locale" content="en_US">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={`${seo.title} | ${site.name}`}>
  <meta name="twitter:description" content={seo.description}>
  <meta name="twitter:image" content={`${site.url}${seo.ogImage || site.ogImage}`}>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.png" type="image/png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/manifest.json">

  <!-- Preload fonts -->
  {site.fontsPreload && site.fontsPreload.map((font: string) => (
    <link rel="preload" href={font} as="font" type="font/woff2" crossorigin>
  ))}
  <ClientRouter />

  <!-- Google Tag Manager -->
  <script is:inline>{`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-P5338CS');`}</script>
</head>
<body class="font-primary antialiased">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P5338CS" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[200] focus:bg-primary focus:text-white focus:py-xs focus:px-s focus:rounded focus:text-text-s">
    Skip to main content
  </a>

  <div class="cv-container">
    <div class="cv-wrapper">
      <!-- Sidebar card (photo + name + social only) -->
      <aside class="cv-sidebar" role="complementary" aria-label="Personal information">
        <div class="cv-sidebar__photo">
          <img src="/images/thomas-rouaud.jpg" alt="Thomas Rouaud" width="300" height="300" loading="eager" />
        </div>
        <h1 class="cv-sidebar__name">Thomas Rouaud</h1>
        <p class="cv-sidebar__title">Digital & growth marketing</p>
        {site.social && site.social.length > 0 && (
          <ul class="cv-sidebar__social">
            {site.social.map((s) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} class="cv-sidebar__social-link">
                  <Icon name={toIconName(s.icon)} class="w-5 h-5" aria-hidden="true" />
                </a>
              </li>
            ))}
          </ul>
        )}
      </aside>

      <!-- Main content -->
      <main id="main-content" class="cv-main" data-pagefind-body>
        <slot />
      </main>
    </div>

    <!-- Footer -->
    <footer class="cv-footer" role="contentinfo">
      <a href="https://lausanne.marketing/" target="_blank" rel="noopener">Website made by Lausanne Marketing //</a>
    </footer>
  </div>

  <!-- Scroll to top -->
  <a href="#main-content" class="cv-scroll-top" aria-label="Scroll to top">
    <Icon name="ph:arrow-up" class="w-5 h-5" aria-hidden="true" />
  </a>

  <JsonLd site={site} breadcrumb={breadcrumb} currentUrl={currentUrl} isHome={isHome} />

  <script src="../scripts/main.ts"></script>
</body>
</html>
